// Metin2 CMS — Prisma Schema
// Datenbank: metin2_cms (wird automatisch von install.sh angelegt)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("CMS_DATABASE_URL")
}

// ============================================================
// Module
// ============================================================
model Module {
  id        String   @id @default(cuid())
  name      String
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  config    Json? // Modul-spezifische Einstellungen
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modules")
}

// ============================================================
// Themes
// ============================================================
model Theme {
  id        String   @id
  name      String
  isDefault Boolean  @default(false)
  config    String   @db.LongText // JSON mit CSS-Variablen
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("themes")
}

// ============================================================
// Users (Admin-Panel)
// ============================================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  accountId Int?     @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

// ============================================================
// News / Announcements
// ============================================================
model News {
  id        String       @id @default(cuid())
  title     String
  content   String       @db.LongText
  excerpt   String?
  published Boolean      @default(false)
  pinned    Boolean      @default(false)
  category  NewsCategory @default(NEWS)
  authorId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("news")
}

enum NewsCategory {
  NEWS
  UPDATE
  EVENT
  MAINTENANCE
}

// ============================================================
// Item Shop
// ============================================================
model ShopCategory {
  id     String     @id @default(cuid())
  name   String
  icon   String?
  order  Int        @default(0)
  active Boolean    @default(true)
  items  ShopItem[]

  @@map("shop_categories")
}

model ShopItem {
  id             String        @id @default(cuid())
  name           String
  description    String?
  price          Int
  currency       String        @default("DR")
  imageUrl       String?
  itemVnum       Int? // Metin2 Item VNUM
  itemTemplateId String?
  itemTemplate   ItemTemplate? @relation(fields: [itemTemplateId], references: [id])
  enabled        Boolean       @default(true)
  categoryId     String
  category       ShopCategory  @relation(fields: [categoryId], references: [id])
  count          Int           @default(1)
  defaultEnchants Json?
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("shop_items")
}

// ============================================================
// Einstellungen
// ============================================================
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ============================================================
// Server-Status (gecacht)
// ============================================================
model ServerStatus {
  id         String   @id @default(cuid())
  channel    String
  online     Boolean  @default(false)
  players    Int      @default(0)
  maxPlayers Int      @default(0)
  load       String   @default("LOW") // LOW | MEDIUM | HIGH
  updatedAt  DateTime @updatedAt

  @@map("server_status")
}

// ============================================================
// Item System
// ============================================================
enum ItemGrade {
  NORMAL
  RARE
  EPIC
  LEGENDARY
}

model ItemTemplate {
  id          String    @id @default(cuid())
  vnum        Int       @unique
  name        String
  description String?   @db.Text
  iconUrl     String?
  itemType    String
  grade       ItemGrade @default(NORMAL)
  attributes  Json?
  enabled     Boolean   @default(true)

  shopItems    ShopItem[]
  storageItems WebStorageItem[]
  transfers    ItemTransfer[]
  adminGrants  AdminItemGrant[]
  trashedItems WebStorageTrash[]

  @@map("item_templates")
}

model WebStorage {
  id        String            @id @default(cuid())
  accountId Int               @unique
  maxSlots  Int               @default(1000)
  items     WebStorageItem[]
  transfers ItemTransfer[]
  trash     WebStorageTrash[]

  @@map("web_storage")
}

model WebStorageItem {
  id         String       @id @default(cuid())
  storageId  String
  storage    WebStorage   @relation(fields: [storageId], references: [id], onDelete: Cascade)
  templateId String
  template   ItemTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  slot       Int
  count      Int          @default(1)
  enchants   Json?

  @@unique([storageId, slot])
  @@map("web_storage_items")
}

enum TransferStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  ROLLED_BACK
}

model ItemTransfer {
  id             String         @id @default(cuid())
  storageId      String
  storage        WebStorage     @relation(fields: [storageId], references: [id], onDelete: Cascade)
  itemTemplateId String
  itemTemplate   ItemTemplate   @relation(fields: [itemTemplateId], references: [id], onDelete: Restrict)
  count          Int            @default(1)
  enchants       Json?
  status         TransferStatus @default(PENDING)
  errorMsg       String?        @db.Text
  requestedAt    DateTime       @default(now())
  processedAt    DateTime?

  @@index([status])
  @@index([storageId])
  @@map("item_transfers")
}

model AdminItemGrant {
  id             String        @id @default(cuid())
  adminId        String?
  accountId      Int
  itemTemplateId String?
  itemTemplate   ItemTemplate? @relation(fields: [itemTemplateId], references: [id], onDelete: Restrict)
  count          Int           @default(1)
  destination    String        @default("web")
  note           String?       @db.Text
  grantedAt      DateTime      @default(now())
  
  characterName  String?
  itemVnum       Int?
  itemCount      Int           @default(1)
  enchants       Json?
  status         String        @default("PENDING")
  grantedBy      String        @default("ADMIN")

  @@map("admin_item_grants")
}

model WebStorageTrash {
  id         String       @id @default(cuid())
  storageId  String
  storage    WebStorage   @relation(fields: [storageId], references: [id], onDelete: Cascade)
  templateId String
  template   ItemTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  count      Int          @default(1)
  enchants   Json?
  deletedAt  DateTime     @default(now())
  expiresAt  DateTime

  @@map("web_storage_trash")
}

model CoinBalance {
  id          String   @id @default(cuid())
  accountId   Int      @unique
  dr          Int      @default(0)
  dm          Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@map("coin_balances")
}

model CoinTransaction {
  id          String            @id @default(cuid())
  accountId   Int
  type        CoinType
  amount      Int
  reason      TransactionReason
  description String?
  createdAt   DateTime          @default(now())

  @@map("coin_transactions")
}

enum CoinType {
  DR
  DM
}

enum TransactionReason {
  ADMIN_GRANT
  PURCHASE
  SHOP_BUY
  DM_CASHBACK
  ADMIN_DEDUCT
}
