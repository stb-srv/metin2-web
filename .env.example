# ===========================
# Metin2 Web CMS — Umgebungsvariablen
# ===========================

# CMS Datenbank (wird automatisch angelegt)
CMS_DATABASE_URL="mysql://cms_user:DEIN_PASSWORT@localhost:3306/metin2_cms"

# Metin2 Game Datenbank (nur lesen!)
GAME_DATABASE_URL="mysql://cms_user:DEIN_PASSWORT@localhost:3306/metin2"

# MySQL Root-Zugang (nur für install.sh benötigt)
MYSQL_ROOT_PASSWORD="root_passwort"
MYSQL_ROOT_HOST="localhost"

# CMS DB User (wird von install.sh angelegt)
CMS_DB_USER="cms_user"
CMS_DB_PASSWORD="sicheres_cms_passwort"
CMS_DB_NAME="metin2_cms"

# Metin2 Game DB Name
GAME_DB_NAME="metin2"

# NextAuth
NEXTAUTH_SECRET="generiere_mit_openssl_rand_-base64_32"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_SITE_NAME="Mein Metin2 Server"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
